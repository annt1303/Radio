{
  "name": "discord-music-bot",
  "version": "1.0.0",
  "description": "Discord Music Bot with TypeScript, discord.js, play-dl and spotify-url-info",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "register": "ts-node src/register-commands.ts"
  },
  "dependencies": {
    "@discordjs/voice": "^0.19.2",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "ffmpeg-static": "^5.3.0",
    "isomorphic-unfetch": "^4.0.2",
    "libsodium-wrappers": "^0.8.4",
    "opusscript": "^0.1.1",
    "play-dl": "^1.9.7",
    "spotify-url-info": "^3.3.0",
    "youtube-dl-exec": "^3.1.7"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "nodemon": "^3.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.2"
  }
}
